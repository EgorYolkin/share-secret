#!/usr/bin/env bash
set -euo pipefail

APP_NAME="share-secret"
APP_VERSION="v1.0.2"
GITHUB_REPO_SSH="git@github.com:EgorYolkin/share-secret.git"
GITHUB_REPO_HTTPS="https://github.com/EgorYolkin/share-secret.git"
RAW_BASE_URL="https://raw.githubusercontent.com/EgorYolkin/share-secret"
SHARE_SECRET_TMP_FILE=""

get_user_config_path() {
  local os
  os="$(uname -s)"

  case "$os" in
    Darwin)
      echo "$HOME/Library/Application Support/$APP_NAME/config.yml"
      ;;
    Linux)
      if [[ -n "${XDG_CONFIG_HOME:-}" ]]; then
        echo "$XDG_CONFIG_HOME/$APP_NAME/config.yml"
      else
        echo "$HOME/.config/$APP_NAME/config.yml"
      fi
      ;;
    *)
      echo "$HOME/.${APP_NAME}/config.yml"
      ;;
  esac
}

get_global_config_path() {
  local os
  os="$(uname -s)"

  case "$os" in
    Darwin)
      echo "/Library/Application Support/$APP_NAME/config.yml"
      ;;
    Linux)
      echo "/etc/$APP_NAME/config.yml"
      ;;
    *)
      echo "/etc/$APP_NAME/config.yml"
      ;;
  esac
}

read_yaml_value() {
  local file="$1"
  local key="$2"

  if [[ ! -f "$file" ]]; then
    return 1
  fi

  awk -F ':' -v k="$key" '
    $1 ~ "^[[:space:]]*" k "[[:space:]]*$" {
      v = substr($0, index($0, ":") + 1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
      gsub(/^"|"$/, "", v)
      gsub(/^\047|\047$/, "", v)
      print v
      exit
    }
  ' "$file"
}

resolve_output_dir() {
  local configured="$1"

  if [[ -z "$configured" || "$configured" == "." ]]; then
    pwd
    return 0
  fi

  if [[ "$configured" = ~* ]]; then
    configured="${HOME}${configured#\~}"
  fi

  if [[ "$configured" = /* ]]; then
    echo "$configured"
  else
    echo "$(pwd)/$configured"
  fi
}

get_effective_config_path() {
  if [[ -n "${SHARE_SECRET_CONFIG:-}" ]]; then
    echo "$SHARE_SECRET_CONFIG"
    return 0
  fi

  local user_config global_config
  user_config="$(get_user_config_path)"
  global_config="$(get_global_config_path)"

  if [[ -f "$user_config" ]]; then
    echo "$user_config"
  elif [[ -f "$global_config" ]]; then
    echo "$global_config"
  else
    echo "$user_config"
  fi
}

get_target_config_path() {
  local target_scope="$1"

  if [[ -n "${SHARE_SECRET_CONFIG:-}" ]]; then
    echo "$SHARE_SECRET_CONFIG"
    return 0
  fi

  if [[ "$target_scope" == "global" ]]; then
    get_global_config_path
  else
    get_user_config_path
  fi
}

load_output_dir_raw() {
  local config_path configured
  config_path="$(get_effective_config_path)"
  configured="$(read_yaml_value "$config_path" "output_dir" || true)"

  if [[ -z "$configured" ]]; then
    echo "."
  else
    echo "$configured"
  fi
}

load_output_dir_from_config() {
  resolve_output_dir "$(load_output_dir_raw)"
}

load_encryption_mode_from_config() {
  local config_path mode
  config_path="$(get_effective_config_path)"
  mode="$(read_yaml_value "$config_path" "encryption_mode" || true)"

  if [[ "$mode" != "zip" && "$mode" != "openssl" ]]; then
    echo "zip"
  else
    echo "$mode"
  fi
}

load_skip_update_version_from_config() {
  local config_path v
  config_path="$(get_effective_config_path)"
  v="$(read_yaml_value "$config_path" "skip_update_version" || true)"
  echo "$v"
}

load_macos_open_share_menu_from_config() {
  local config_path v
  config_path="$(get_effective_config_path)"
  v="$(read_yaml_value "$config_path" "macos_open_share_menu" || true)"

  if [[ "$v" == "true" || "$v" == "1" ]]; then
    echo "true"
  else
    echo "false"
  fi
}

write_config() {
  local target_scope="$1"
  local output_dir="$2"
  local encryption_mode="$3"
  local skip_update_version="$4"
  local macos_open_share_menu="$5"
  local config_path config_dir

  config_path="$(get_target_config_path "$target_scope")"
  config_dir="$(dirname "$config_path")"
  mkdir -p "$config_dir"

  cat > "$config_path" <<CONFIG
# share-secret config
# output_dir: where encrypted files are stored.
# Use "." to save in the current directory.
output_dir: "$output_dir"

# encryption_mode: zip (default) or openssl
encryption_mode: "$encryption_mode"

# skip_update_version: do not show update prompt for this version.
# Empty string means no skipped version.
skip_update_version: "$skip_update_version"

# macos_open_share_menu: on macOS try to open Finder Share menu after encrypt/decrypt.
macos_open_share_menu: "$macos_open_share_menu"
CONFIG

  echo "Config saved: $config_path"
}

persist_skip_version() {
  local new_skip="$1"
  local current_output current_mode current_share_menu
  current_output="$(load_output_dir_raw)"
  current_mode="$(load_encryption_mode_from_config)"
  current_share_menu="$(load_macos_open_share_menu_from_config)"
  write_config "user" "$current_output" "$current_mode" "$new_skip" "$current_share_menu" >/dev/null
}

is_newer_version() {
  local current="$1"
  local latest="$2"

  current="${current#v}"
  latest="${latest#v}"

  if [[ "$current" == "$latest" ]]; then
    return 1
  fi

  if [[ "$(printf '%s\n%s\n' "$current" "$latest" | sort -V | tail -n1)" == "$latest" ]]; then
    return 0
  fi

  return 1
}

fetch_latest_tag() {
  local tags

  tags="$(git ls-remote --tags --refs "$GITHUB_REPO_HTTPS" 2>/dev/null | awk -F/ '{print $3}' | grep -E '^v[0-9]+(\.[0-9]+)*$' || true)"

  if [[ -z "$tags" ]]; then
    echo ""
    return 0
  fi

  echo "$tags" | sort -V | tail -n1
}

self_update_to_tag() {
  local tag="$1"
  local target_dir tmp_file url

  if ! command -v curl >/dev/null 2>&1; then
    echo "Update skipped: curl is required." >&2
    return 1
  fi

  target_dir="/usr/local/bin"
  if [[ -d "/opt/homebrew/bin" ]]; then
    target_dir="/opt/homebrew/bin"
  fi

  tmp_file="$(mktemp)"
  url="$RAW_BASE_URL/$tag/bin/share-secret"

  if ! curl -fsSL "$url" -o "$tmp_file"; then
    rm -f "$tmp_file"
    echo "Update failed: cannot download $url" >&2
    return 1
  fi

  if ! install -m 0755 "$tmp_file" "$target_dir/share-secret" 2>/dev/null; then
    rm -f "$tmp_file"
    echo "Update requires elevated privileges. Run:" >&2
    echo "  sudo install -m 0755 $tmp_file $target_dir/share-secret" >&2
    return 1
  fi

  rm -f "$tmp_file"
  echo "Updated share-secret to $tag"
  return 0
}

maybe_prompt_update() {
  local latest skipped choice

  if [[ "${SHARE_SECRET_NO_UPDATE_CHECK:-}" == "1" ]]; then
    return 0
  fi

  if [[ ! -t 0 || ! -t 1 ]]; then
    return 0
  fi

  latest="$(fetch_latest_tag)"
  if [[ -z "$latest" ]]; then
    return 0
  fi

  if ! is_newer_version "$APP_VERSION" "$latest"; then
    return 0
  fi

  skipped="$(load_skip_update_version_from_config)"
  if [[ "$skipped" == "$latest" ]]; then
    return 0
  fi

  echo "A new version is available: $latest (current: $APP_VERSION)"
  echo "1) skip update"
  echo "2) update"
  printf "Choose [1/2]: "
  read -r choice || true

  case "$choice" in
    2)
      if self_update_to_tag "$latest"; then
        echo "Rerun your command with the updated version."
        exit 0
      fi
      ;;
    1|*)
      persist_skip_version "$latest"
      echo "Skipped update for $latest. You will be prompted again when a newer release appears."
      ;;
  esac
}

setup_command() {
  local profile="manual"
  local scope="user"
  local output_dir="."
  local encryption_mode="zip"
  local macos_open_share_menu="false"
  local skip_update_version

  if [[ "${1:-}" == "fast" || "${1:-}" == "secure" || "${1:-}" == "manual" ]]; then
    profile="$1"
    shift
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --global)
        scope="global"
        shift
        ;;
      --user)
        scope="user"
        shift
        ;;
      --output-dir)
        if [[ -z "${2:-}" ]]; then
          echo "Error: --output-dir requires a value" >&2
          exit 1
        fi
        output_dir="$2"
        shift 2
        ;;
      --encryption-mode)
        if [[ -z "${2:-}" ]]; then
          echo "Error: --encryption-mode requires a value" >&2
          exit 1
        fi
        encryption_mode="$2"
        shift 2
        ;;
      --macos-share-menu)
        if [[ -z "${2:-}" ]]; then
          echo "Error: --macos-share-menu requires true|false" >&2
          exit 1
        fi
        macos_open_share_menu="$2"
        shift 2
        ;;
      -h|--help)
        cat <<HELP
Usage:
  share-secret setup [fast|secure|manual] [--user|--global] [--output-dir <path>] [--encryption-mode zip|openssl] [--macos-share-menu true|false] [--macos-share-menu true|false]

Profiles:
  fast    output_dir="." + encryption_mode="zip"
  secure  output_dir="." + encryption_mode="openssl"
  manual  full custom setup with flags

Examples:
  share-secret setup fast
  share-secret setup secure
  share-secret setup manual --user --output-dir ~/Secrets --encryption-mode openssl
HELP
        return 0
        ;;
      *)
        echo "Error: unknown setup option '$1'" >&2
        exit 1
        ;;
    esac
  done

  case "$profile" in
    fast)
      output_dir="."
      encryption_mode="zip"
      ;;
    secure)
      output_dir="."
      encryption_mode="openssl"
      ;;
    manual)
      ;;
  esac

  if [[ "$encryption_mode" != "zip" && "$encryption_mode" != "openssl" ]]; then
    echo "Error: --encryption-mode must be 'zip' or 'openssl'" >&2
    exit 1
  fi
  if [[ "$macos_open_share_menu" != "true" && "$macos_open_share_menu" != "false" ]]; then
    echo "Error: --macos-share-menu must be 'true' or 'false'" >&2
    exit 1
  fi

  if [[ "$scope" == "global" ]] && [[ "${EUID:-$(id -u)}" -ne 0 ]] && [[ -z "${SHARE_SECRET_CONFIG:-}" ]]; then
    echo "Error: global config requires root privileges" >&2
    echo "Run with sudo: sudo share-secret setup $profile --global --output-dir \"$output_dir\" --encryption-mode \"$encryption_mode\"" >&2
    exit 1
  fi

  skip_update_version="$(load_skip_update_version_from_config)"
  write_config "$scope" "$output_dir" "$encryption_mode" "$skip_update_version" "$macos_open_share_menu"
  echo "Profile: $profile"
  echo "Scope: $scope"
  echo "output_dir: $output_dir"
  echo "encryption_mode: $encryption_mode"
  echo "macos_open_share_menu: $macos_open_share_menu"
}

reveal_and_share_macos() {
  local file_path="$1"
  local password="${2:-}"
  local password_file=""
  open -R "$file_path" >/dev/null 2>&1 || true

  if [[ "$(uname -s)" != "Darwin" ]]; then
    return 0
  fi
  if [[ "$(load_macos_open_share_menu_from_config)" != "true" ]]; then
    return 0
  fi
  if ! command -v osascript >/dev/null 2>&1; then
    return 0
  fi

  if [[ -n "$password" ]]; then
    password_file="$(mktemp /tmp/share-secret-password-XXXXXX.txt)"
    printf "Password: %s\n" "$password" > "$password_file"
  fi

  if [[ -n "$password_file" ]]; then
    osascript <<APPLE >/dev/null 2>&1 || true
set p1 to POSIX file "$file_path"
set p2 to POSIX file "$password_file"
tell application "Finder"
  activate
  reveal p1
  set selection to {p1, p2}
end tell
delay 0.2
tell application "System Events"
  tell process "Finder"
    try
      click menu item "Share…" of menu 1 of menu bar item "File" of menu bar 1
    on error
      try
        click menu item "Поделиться…" of menu 1 of menu bar item "Файл" of menu bar 1
      end try
    end try
  end tell
end tell
APPLE
    return 0
  fi

  osascript <<APPLE >/dev/null 2>&1 || true
set p to POSIX file "$file_path"
tell application "Finder"
  activate
  reveal p
  select p
end tell
delay 0.2
tell application "System Events"
  tell process "Finder"
    try
      click menu item "Share…" of menu 1 of menu bar item "File" of menu bar 1
    on error
      try
        click menu item "Поделиться…" of menu 1 of menu bar item "Файл" of menu bar 1
      end try
    end try
  end tell
end tell
APPLE
}

cleanup_tmp() {
  if [[ -n "$SHARE_SECRET_TMP_FILE" ]]; then
    rm -f "$SHARE_SECRET_TMP_FILE"
    rmdir "$(dirname "$SHARE_SECRET_TMP_FILE")" 2>/dev/null || true
  fi
}

ensure_dependencies_for_encrypt() {
  if ! command -v openssl >/dev/null 2>&1; then
    echo "Error: openssl is required but not installed" >&2
    exit 1
  fi

  if ! command -v open >/dev/null 2>&1; then
    echo "Error: this command currently supports macOS only (missing 'open')" >&2
    exit 1
  fi
}

encrypt_to_zip() {
  local text="$1"
  local out_path="$2"
  local password="$3"
  local entry_name="$4"
  local tmp_dir

  if ! command -v zip >/dev/null 2>&1; then
    echo "Error: zip is required for encryption_mode=zip" >&2
    exit 1
  fi

  tmp_dir="$(mktemp -d)"
  SHARE_SECRET_TMP_FILE="$tmp_dir/$entry_name"
  trap cleanup_tmp EXIT

  printf "%s" "$text" > "$SHARE_SECRET_TMP_FILE"
  zip -j -P "$password" "$out_path" "$SHARE_SECRET_TMP_FILE" >/dev/null
}

encrypt_to_openssl() {
  local text="$1"
  local out_path="$2"
  local password="$3"

  SHARE_SECRET_TMP_FILE="$(mktemp)"
  trap cleanup_tmp EXIT

  printf "%s" "$text" > "$SHARE_SECRET_TMP_FILE"
  openssl enc -aes-256-cbc -pbkdf2 -salt -in "$SHARE_SECRET_TMP_FILE" -out "$out_path" -pass "pass:$password"
}

encrypt_command() {
  ensure_dependencies_for_encrypt
  maybe_prompt_update

  local text="${1:-}"
  local out_file_input="${2:-secret}"
  local out_file out_dir out_path password mode

  if [[ -z "$text" ]]; then
    echo "Enter secret text. Finish with Ctrl+D:"
    text="$(cat)"
  fi

  if [[ -z "$text" ]]; then
    echo "Error: empty text." >&2
    exit 1
  fi

  out_file="$out_file_input"
  out_dir="$(load_output_dir_from_config)"
  mode="$(load_encryption_mode_from_config)"

  if [[ "$mode" == "zip" ]]; then
    if [[ "$out_file" != *.zip ]]; then
      out_file="${out_file}.zip"
    fi
  else
    if [[ "$out_file" != *.txt ]]; then
      out_file="${out_file}.txt"
    fi
  fi

  mkdir -p "$out_dir"
  out_path="$out_dir/$out_file"

  password="$(openssl rand -base64 24 | tr -d '\n')"

  if [[ "$mode" == "zip" ]]; then
    encrypt_to_zip "$text" "$out_path" "$password" "${out_file%.zip}.txt"
  else
    encrypt_to_openssl "$text" "$out_path" "$password"
  fi

  echo "Encrypted file: $out_path"
  echo "Mode: $mode"
  echo "Password: $password"
  if command -v pbcopy >/dev/null 2>&1; then
    if printf "%s" "$password" | pbcopy 2>/dev/null; then
      echo "Password copied to clipboard."
    fi
  fi
  reveal_and_share_macos "$out_path" "$password"
}

write_command() {
  local out_file_input="${1:-secret}"
  echo "Multi-line mode. Enter text and finish with Ctrl+D:"
  encrypt_command "$(cat)" "$out_file_input"
}

decrypt_zip() {
  local in_path="$1"
  local password="$2"
  local out_path="$3"

  if ! command -v unzip >/dev/null 2>&1; then
    echo "Error: unzip is required to open .zip secrets" >&2
    exit 1
  fi

  if ! unzip -P "$password" -p "$in_path" > "$out_path" 2>/dev/null; then
    rm -f "$out_path"
    echo "Error: failed to decrypt zip. Check password/file." >&2
    exit 1
  fi
}

decrypt_openssl() {
  local in_path="$1"
  local password="$2"
  local out_path="$3"

  if ! openssl enc -d -aes-256-cbc -pbkdf2 -in "$in_path" -out "$out_path" -pass "pass:$password" 2>/dev/null; then
    rm -f "$out_path"
    echo "Error: failed to decrypt openssl file. Check password/file." >&2
    exit 1
  fi
}

open_command() {
  ensure_dependencies_for_encrypt
  maybe_prompt_update

  local in_path="${1:-}"
  local password="${2:-}"
  local out_path mode

  if [[ -z "$in_path" || -z "$password" ]]; then
    cat <<HELP
Usage:
  share-secret open <path-to-encrypted-file> <password> [output-file]
HELP
    exit 1
  fi

  if [[ ! -f "$in_path" ]]; then
    echo "Error: file not found: $in_path" >&2
    exit 1
  fi

  out_path="${3:-}"
  if [[ -z "$out_path" ]]; then
    if [[ "$in_path" == *.zip ]]; then
      out_path="${in_path%.zip}.txt"
    else
      out_path="${in_path}.decrypted.txt"
    fi
  fi

  mode="openssl"
  if [[ "$in_path" == *.zip ]]; then
    mode="zip"
  fi

  if [[ "$mode" == "zip" ]]; then
    decrypt_zip "$in_path" "$password" "$out_path"
  else
    decrypt_openssl "$in_path" "$password" "$out_path"
  fi

  echo "Decrypted file: $out_path"
  echo "Mode: $mode"
  reveal_and_share_macos "$out_path"
}

usage() {
  cat <<HELP
Usage:
  share-secret "text to encrypt" [output-file]
  share-secret write [output-file]
  share-secret open <path-to-encrypted-file> <password> [output-file]
  share-secret setup [fast|secure|manual] [--user|--global] [--output-dir <path>] [--encryption-mode zip|openssl] [--macos-share-menu true|false]

Setup profiles:
  fast    zip encryption + current directory
  secure  openssl encryption + current directory
  manual  custom config

Notes:
  - Default encryption mode is zip.
  - Without config, files are saved in current directory.
  - User config has priority over global config.
HELP
}

main() {
  case "${1:-}" in
    setup)
      shift
      setup_command "$@"
      ;;
    open)
      shift
      open_command "$@"
      ;;
    write)
      shift
      write_command "$@"
      ;;
    -h|--help)
      usage
      ;;
    *)
      encrypt_command "$@"
      ;;
  esac
}

main "$@"
