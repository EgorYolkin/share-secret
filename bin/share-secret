#!/usr/bin/env bash
set -euo pipefail

if ! command -v openssl >/dev/null 2>&1; then
  echo "Error: openssl is required but not installed" >&2
  exit 1
fi

if ! command -v open >/dev/null 2>&1; then
  echo "Error: this command currently supports macOS only (missing 'open')" >&2
  exit 1
fi

TEXT="${1:-}"
OUT_FILE_INPUT="${2:-secret.txt}"

if [[ -z "$TEXT" ]]; then
  echo "Usage: share-secret \"text to encrypt\" [output_file.txt]" >&2
  exit 1
fi

OUT_FILE="$OUT_FILE_INPUT"
if [[ "$OUT_FILE" != *.txt ]]; then
  OUT_FILE="${OUT_FILE}.txt"
fi

OUT_PATH="$(pwd)/${OUT_FILE}"
PASSWORD="$(openssl rand -base64 24 | tr -d '\n')"
TMP_FILE="$(mktemp)"

cleanup() {
  rm -f "$TMP_FILE"
}
trap cleanup EXIT

printf "%s" "$TEXT" > "$TMP_FILE"
openssl enc -aes-256-cbc -pbkdf2 -salt -in "$TMP_FILE" -out "$OUT_PATH" -pass "pass:$PASSWORD"

echo "Encrypted file: $OUT_PATH"
echo "Password: $PASSWORD"
open -R "$OUT_PATH"
