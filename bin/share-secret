#!/usr/bin/env bash
set -euo pipefail

APP_NAME="share-secret"
SHARE_SECRET_TMP_FILE=""

get_user_config_path() {
  local os
  os="$(uname -s)"

  case "$os" in
    Darwin)
      echo "$HOME/Library/Application Support/$APP_NAME/config.yml"
      ;;
    Linux)
      if [[ -n "${XDG_CONFIG_HOME:-}" ]]; then
        echo "$XDG_CONFIG_HOME/$APP_NAME/config.yml"
      else
        echo "$HOME/.config/$APP_NAME/config.yml"
      fi
      ;;
    *)
      echo "$HOME/.${APP_NAME}/config.yml"
      ;;
  esac
}

get_global_config_path() {
  local os
  os="$(uname -s)"

  case "$os" in
    Darwin)
      echo "/Library/Application Support/$APP_NAME/config.yml"
      ;;
    Linux)
      echo "/etc/$APP_NAME/config.yml"
      ;;
    *)
      echo "/etc/$APP_NAME/config.yml"
      ;;
  esac
}

read_yaml_value() {
  local file="$1"
  local key="$2"

  if [[ ! -f "$file" ]]; then
    return 1
  fi

  awk -F ':' -v k="$key" '
    $1 ~ "^[[:space:]]*" k "[[:space:]]*$" {
      v = substr($0, index($0, ":") + 1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
      gsub(/^"|"$/, "", v)
      gsub(/^\047|\047$/, "", v)
      print v
      exit
    }
  ' "$file"
}

resolve_output_dir() {
  local configured="$1"

  if [[ -z "$configured" || "$configured" == "." ]]; then
    pwd
    return 0
  fi

  if [[ "$configured" = ~* ]]; then
    configured="${HOME}${configured#\~}"
  fi

  if [[ "$configured" = /* ]]; then
    echo "$configured"
  else
    echo "$(pwd)/$configured"
  fi
}

get_effective_config_path() {
  if [[ -n "${SHARE_SECRET_CONFIG:-}" ]]; then
    echo "$SHARE_SECRET_CONFIG"
    return 0
  fi

  local user_config global_config
  user_config="$(get_user_config_path)"
  global_config="$(get_global_config_path)"

  if [[ -f "$user_config" ]]; then
    echo "$user_config"
  elif [[ -f "$global_config" ]]; then
    echo "$global_config"
  else
    echo "$user_config"
  fi
}

get_target_config_path() {
  local target_scope="$1"

  if [[ -n "${SHARE_SECRET_CONFIG:-}" ]]; then
    echo "$SHARE_SECRET_CONFIG"
    return 0
  fi

  if [[ "$target_scope" == "global" ]]; then
    get_global_config_path
  else
    get_user_config_path
  fi
}

load_output_dir_from_config() {
  local config_path configured
  config_path="$(get_effective_config_path)"
  configured="$(read_yaml_value "$config_path" "output_dir" || true)"
  resolve_output_dir "$configured"
}

write_config() {
  local target_scope="$1"
  local output_dir="$2"
  local config_path config_dir

  config_path="$(get_target_config_path "$target_scope")"
  config_dir="$(dirname "$config_path")"
  mkdir -p "$config_dir"

  cat > "$config_path" <<CONFIG
# share-secret config
# output_dir: where encrypted files are stored.
# Use "." to save in the current directory (default behavior).
output_dir: "$output_dir"
CONFIG

  echo "Config saved: $config_path"
}

setup_command() {
  local scope="user"
  local output_dir="."

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --global)
        scope="global"
        shift
        ;;
      --user)
        scope="user"
        shift
        ;;
      --output-dir)
        if [[ -z "${2:-}" ]]; then
          echo "Error: --output-dir requires a value" >&2
          exit 1
        fi
        output_dir="$2"
        shift 2
        ;;
      -h|--help)
        cat <<HELP
Usage:
  share-secret setup [--user|--global] [--output-dir <path>]

Examples:
  share-secret setup --user --output-dir ~/Secrets
  share-secret setup --global --output-dir /var/share-secret
  share-secret setup --user --output-dir .
HELP
        return 0
        ;;
      *)
        echo "Error: unknown setup option '$1'" >&2
        exit 1
        ;;
    esac
  done

  if [[ "$scope" == "global" ]] && [[ "${EUID:-$(id -u)}" -ne 0 ]] && [[ -z "${SHARE_SECRET_CONFIG:-}" ]]; then
    echo "Error: global config requires root privileges" >&2
    echo "Run with sudo: sudo share-secret setup --global --output-dir \"$output_dir\"" >&2
    exit 1
  fi

  write_config "$scope" "$output_dir"
  echo "Scope: $scope"
  echo "output_dir: $output_dir"
}

cleanup_tmp() {
  if [[ -n "$SHARE_SECRET_TMP_FILE" ]]; then
    rm -f "$SHARE_SECRET_TMP_FILE"
  fi
}

encrypt_command() {
  if ! command -v openssl >/dev/null 2>&1; then
    echo "Error: openssl is required but not installed" >&2
    exit 1
  fi

  if ! command -v open >/dev/null 2>&1; then
    echo "Error: this command currently supports macOS only (missing 'open')" >&2
    exit 1
  fi

  local text="${1:-}"
  local out_file_input="${2:-secret.txt}"
  local out_file out_dir out_path password

  if [[ -z "$text" ]]; then
    cat <<HELP
Usage:
  share-secret "text to encrypt" [output_file.txt]
  share-secret setup [--user|--global] [--output-dir <path>]
HELP
    exit 1
  fi

  out_file="$out_file_input"
  if [[ "$out_file" != *.txt ]]; then
    out_file="${out_file}.txt"
  fi

  out_dir="$(load_output_dir_from_config)"
  mkdir -p "$out_dir"
  out_path="$out_dir/$out_file"

  password="$(openssl rand -base64 24 | tr -d '\n')"
  SHARE_SECRET_TMP_FILE="$(mktemp)"
  trap cleanup_tmp EXIT

  printf "%s" "$text" > "$SHARE_SECRET_TMP_FILE"
  openssl enc -aes-256-cbc -pbkdf2 -salt -in "$SHARE_SECRET_TMP_FILE" -out "$out_path" -pass "pass:$password"

  echo "Encrypted file: $out_path"
  echo "Password: $password"
  open -R "$out_path"
}

main() {
  case "${1:-}" in
    setup)
      shift
      setup_command "$@"
      ;;
    -h|--help)
      cat <<HELP
Usage:
  share-secret "text to encrypt" [output_file.txt]
  share-secret setup [--user|--global] [--output-dir <path>]

Notes:
  - Without config, files are saved in the current directory.
  - User config has priority over global config.
HELP
      ;;
    *)
      encrypt_command "$@"
      ;;
  esac
}

main "$@"
